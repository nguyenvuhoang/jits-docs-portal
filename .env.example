# Change this in production. It is used to sign project access cookies.
GUIDE_AUTH_SECRET=change-this-to-a-long-random-secret

# Option 1: project keys by env var
GUIDE_KEY_EMI=emi@2026
GUIDE_KEY_CMI=cmi@2026

# Option 2: override all keys using JSON
# GUIDE_KEYS_JSON={"emi":"emi@2026","cmi":"cmi@2026"}

# Unlock duration in hours
GUIDE_UNLOCK_HOURS=8
